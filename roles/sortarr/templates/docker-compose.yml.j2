---
# Generated by Ansible (sortarr role). Do not edit manually.
# Sortarr is READ-ONLY: it never moves, renames, or deletes media. Config +
# cache persist to the bind-mounted host dir.
services:
  sortarr:
    container_name: {{ sortarr_container_name }}
    image: {{ sortarr_image }}
    restart: unless-stopped
    ports:
      - "{{ sortarr_bind_address }}:{{ sortarr_web_port }}:8787"
    environment:
      SONARR_URL: "{{ sortarr_sonarr_url }}"
      SONARR_API_KEY: "{{ sortarr_sonarr_api_key }}"
      RADARR_URL: "{{ sortarr_radarr_url }}"
      RADARR_API_KEY: "{{ sortarr_radarr_api_key }}"
{% if sortarr_plex_token | length > 0 %}
      PLEX_URL: "{{ sortarr_plex_url }}"
      PLEX_TOKEN: "{{ sortarr_plex_token }}"
{% endif %}
      BASIC_AUTH_USER: "{{ sortarr_basic_auth_user }}"
      BASIC_AUTH_PASS: "{{ sortarr_basic_auth_pass }}"
      SORTARR_LOCAL_AUTH_BYPASS: "{{ '1' if sortarr_local_auth_bypass else '0' }}"
      SORTARR_LOCAL_AUTH_BYPASS_CIDRS: "{{ sortarr_local_auth_bypass_cidrs }}"
      SORTARR_PROXY_MODE: "{{ sortarr_proxy_mode }}"
      SORTARR_WAITRESS_TRUSTED_PROXY: "{{ sortarr_waitress_trusted_proxy }}"
    volumes:
      - {{ sortarr_config_dir }}:/data
