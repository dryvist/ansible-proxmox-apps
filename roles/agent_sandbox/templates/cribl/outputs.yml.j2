---
# {{ ansible_managed }}
# tcpjson outputs to the HAProxy-fronted Cribl Stream per-CLI frontends. One
# port per CLI so Stream keys routing/enrichment off the frontend (mirrors the
# Mac Edge). The persistent queue buffers events locally across any
# HAProxy/Stream downtime and flushes when the port returns. FQDN only.
outputs:
  cribl_claude:
    type: tcpjson
    host: {{ agent_sandbox_cribl_stream_host }}
    port: {{ agent_sandbox_cribl_ports.claude }}
    pqEnabled: true
  cribl_codex:
    type: tcpjson
    host: {{ agent_sandbox_cribl_stream_host }}
    port: {{ agent_sandbox_cribl_ports.codex }}
    pqEnabled: true
  cribl_agy:
    type: tcpjson
    host: {{ agent_sandbox_cribl_stream_host }}
    port: {{ agent_sandbox_cribl_ports.gemini }}
    pqEnabled: true
