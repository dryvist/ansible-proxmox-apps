---
# Generated by Ansible (idrac_kvm_docker role). Do not edit manually.
# Credentials are loaded from the sibling .env file (mode 0600, root:root).
services:
{% for t in idrac_kvm_docker_targets %}
  idrac-{{ t.name }}:
    container_name: idrac-{{ t.name }}
    image: {{ idrac_kvm_docker_image }}
    restart: unless-stopped
    ports:
      - "{{ idrac_kvm_docker_bind_address }}:{{ t.host_port }}:5800"
    environment:
      IDRAC_HOST: "${{'{'}}{{ t.env_prefix }}_HOST{{'}'}}"
      IDRAC_USER: "${{'{'}}{{ t.env_prefix }}_USER{{'}'}}"
      IDRAC_PASSWORD: "${{'{'}}{{ t.env_prefix }}_PASSWORD{{'}'}}"
{% if t.keycode_hack | default(false) %}
      IDRAC_KEYCODE_HACK: "TRUE"
{% endif %}
      TZ: "{{ idrac_kvm_docker_tz }}"
    volumes:
      - idrac-{{ t.name }}-app:/app
      - idrac-{{ t.name }}-screenshots:/screenshots
{% if idrac_kvm_docker_iso_dir %}
      - {{ idrac_kvm_docker_iso_dir }}:/iso:ro
{% endif %}
{% endfor %}

volumes:
{% for t in idrac_kvm_docker_targets %}
  idrac-{{ t.name }}-app:
  idrac-{{ t.name }}-screenshots:
{% endfor %}
