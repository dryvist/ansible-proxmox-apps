---
# IPFIX processing pipeline for Cribl Stream
# Generated by Ansible - cribl_docker_stack role
# Sets Splunk index/sourcetype for IPFIX data from UniFi Dream Wall

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  # Set Splunk fields for IPFIX data
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        - name: index
          value: "'netflow'"
        - name: sourcetype
          value: "'ipfix'"
        - name: source
          value: "'ipfix:{{ cribl_docker_stack_netflow_port }}'"
