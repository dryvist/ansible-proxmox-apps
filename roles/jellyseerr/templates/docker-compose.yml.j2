---
# Generated by Ansible (jellyseerr role). Do not edit manually.
# Config (settings.json, db) persists to the bind-mounted host dir.
services:
  jellyseerr:
    container_name: {{ jellyseerr_container_name }}
    image: {{ jellyseerr_image }}
    # Seerr's image ships no init process; init: true reaps zombies (PID 1).
    init: true
    restart: unless-stopped
    ports:
      - "{{ jellyseerr_bind_address }}:{{ jellyseerr_web_port }}:5055"
    environment:
      TZ: "{{ jellyseerr_tz }}"
      LOG_LEVEL: "{{ jellyseerr_log_level }}"
      PORT: "5055"
    volumes:
      - {{ jellyseerr_config_dir }}:/app/config
