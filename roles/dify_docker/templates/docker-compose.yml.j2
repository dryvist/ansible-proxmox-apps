---
# Rendered by Ansible (dify_docker role). Do NOT edit on the host.
# Dify LLMOps stack — bundled Weaviate vector store, Postgres, Redis, sandbox,
# SSRF proxy, and an Nginx entrypoint. Mirrors the upstream
# docker/docker-compose.yaml structure (api/worker/worker_beat share one env via
# a YAML anchor) trimmed to the services this homelab runs. Service names are
# the in-network DNS identifiers, referenced directly; only IPs and ports that
# exist in tofu_data are parametrized.
x-shared-env: &dify-api-worker-env
  LOG_LEVEL: "INFO"
  DEPLOY_ENV: "PRODUCTION"
  SECRET_KEY: "{{ dify_docker_secret_key }}"
  # Public URLs are derived by Dify from the request Host when left blank.
  CONSOLE_API_URL: ""
  CONSOLE_WEB_URL: ""
  SERVICE_API_URL: ""
  APP_API_URL: ""
  APP_WEB_URL: ""
  FILES_URL: ""
  MIGRATION_ENABLED: "true"
  # PostgreSQL (bundled `db` service).
  DB_USERNAME: "{{ dify_docker_db_user }}"
  DB_PASSWORD: "{{ dify_docker_db_password }}"
  DB_HOST: "db"
  DB_PORT: "{{ dify_docker_postgres_port }}"
  DB_DATABASE: "{{ dify_docker_db_name }}"
  # Redis (bundled `redis` service); Celery uses logical DB 1.
  REDIS_HOST: "redis"
  REDIS_PORT: "{{ dify_docker_redis_port }}"
  REDIS_PASSWORD: "{{ dify_docker_redis_password }}"
  REDIS_DB: "0"
  REDIS_USE_SSL: "false"
  CELERY_BROKER_URL: "redis://:{{ dify_docker_redis_password }}@redis:{{ dify_docker_redis_port }}/1"
  BROKER_USE_SSL: "false"
  # Vector store — bundled Weaviate (NOT the external qdrant).
  VECTOR_STORE: "weaviate"
  WEAVIATE_ENDPOINT: "http://weaviate:{{ dify_docker_weaviate_port }}"
  WEAVIATE_API_KEY: "{{ dify_docker_weaviate_api_key }}"
  # File storage on the local bind mount (relative to /app/api).
  STORAGE_TYPE: "opendal"
  OPENDAL_SCHEME: "fs"
  OPENDAL_FS_ROOT: "storage"
  # Code-execution sandbox + its SSRF egress proxy.
  CODE_EXECUTION_ENDPOINT: "http://sandbox:{{ dify_docker_sandbox_port }}"
  CODE_EXECUTION_API_KEY: "{{ dify_docker_sandbox_api_key }}"
  SSRF_PROXY_HTTP_URL: "http://ssrf_proxy:{{ dify_docker_ssrf_proxy_port }}"
  SSRF_PROXY_HTTPS_URL: "http://ssrf_proxy:{{ dify_docker_ssrf_proxy_port }}"
  # Plugin daemon + marketplace. On 1.x model providers ARE plugins, so the api
  # must reach plugin_daemon or no LLM can be configured. PLUGIN_DAEMON_KEY must
  # equal the daemon's SERVER_KEY; INNER_API_KEY_FOR_PLUGIN must equal the
  # daemon's DIFY_INNER_API_KEY (two distinct secrets).
  PLUGIN_DAEMON_URL: "http://plugin_daemon:{{ dify_docker_plugin_daemon_port }}"
  PLUGIN_DAEMON_KEY: "{{ dify_docker_plugin_daemon_key }}"
  PLUGIN_MAX_PACKAGE_SIZE: "52428800"
  INNER_API_KEY_FOR_PLUGIN: "{{ dify_docker_inner_api_key }}"
  MARKETPLACE_ENABLED: "true"
  MARKETPLACE_API_URL: "https://marketplace.dify.ai"
  ENDPOINT_URL_TEMPLATE: "http://localhost/e/{hook_id}"
  # Legacy OpenAI SDK fallback only. Usable Dify models are provisioned through
  # the console model-provider API after first-run setup.
  OPENAI_API_BASE: "{{ dify_docker_model_endpoint_url }}"
  OPENAI_API_KEY: "{{ dify_docker_model_api_key }}"
  # OpenTelemetry export to the homelab collector (group_var, reference only).
  ENABLE_OTEL: "true"
  OTLP_BASE_ENDPOINT: "{{ ai_orchestration_otel_endpoint }}"
  OTEL_EXPORTER_OTLP_PROTOCOL: "http/protobuf"
  # CORS — internal-only deployment behind the homelab reverse proxy.
  WEB_API_CORS_ALLOW_ORIGINS: "*"
  CONSOLE_CORS_ALLOW_ORIGINS: "*"

services:
  api:
    image: {{ dify_docker_api_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      <<: *dify-api-worker-env
      MODE: "api"
      SENTRY_DSN: ""
    depends_on:
      - db
      - redis
      - weaviate
      - sandbox
      - ssrf_proxy
    volumes:
      - {{ dify_docker_data_dir }}/storage:/app/api/storage

  worker:
    image: {{ dify_docker_api_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      <<: *dify-api-worker-env
      MODE: "worker"
      SENTRY_DSN: ""
    depends_on:
      - db
      - redis
      - weaviate
      - sandbox
      - ssrf_proxy
    volumes:
      - {{ dify_docker_data_dir }}/storage:/app/api/storage

  worker_beat:
    image: {{ dify_docker_api_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      <<: *dify-api-worker-env
      MODE: "beat"
    depends_on:
      - db
      - redis

  web:
    image: {{ dify_docker_web_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      CONSOLE_API_URL: "{{ dify_docker_public_url }}"
      APP_API_URL: "{{ dify_docker_public_url }}"
      NEXT_TELEMETRY_DISABLED: "1"

  db:
    image: {{ dify_docker_postgres_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      POSTGRES_USER: "{{ dify_docker_db_user }}"
      POSTGRES_PASSWORD: "{{ dify_docker_db_password }}"
      POSTGRES_DB: "{{ dify_docker_db_name }}"
      PGDATA: "/var/lib/postgresql/data/pgdata"
    volumes:
      - {{ dify_docker_data_dir }}/postgres:/var/lib/postgresql/data
      # Creates the second `dify_plugin` database on first init (empty PGDATA).
      - {{ dify_docker_data_dir }}/postgres-init:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "{{ dify_docker_db_user }}", "-d", "{{ dify_docker_db_name }}"]
      interval: 30s
      timeout: 5s
      retries: 5

  redis:
    image: {{ dify_docker_redis_image }}
    restart: {{ dify_docker_restart_policy }}
    command: redis-server --requirepass {{ dify_docker_redis_password }}
    volumes:
      - {{ dify_docker_data_dir }}/redis:/data

  weaviate:
    image: {{ dify_docker_weaviate_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      PERSISTENCE_DATA_PATH: "/var/lib/weaviate"
      QUERY_DEFAULTS_LIMIT: "25"
      DEFAULT_VECTORIZER_MODULE: "none"
      CLUSTER_HOSTNAME: "node1"
      AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED: "false"
      AUTHENTICATION_APIKEY_ENABLED: "true"
      AUTHENTICATION_APIKEY_ALLOWED_KEYS: "{{ dify_docker_weaviate_api_key }}"
      AUTHENTICATION_APIKEY_USERS: "{{ dify_docker_weaviate_user }}"
      AUTHORIZATION_ADMINLIST_ENABLED: "true"
      AUTHORIZATION_ADMINLIST_USERS: "{{ dify_docker_weaviate_user }}"
    volumes:
      - {{ dify_docker_data_dir }}/weaviate:/var/lib/weaviate

  sandbox:
    image: {{ dify_docker_sandbox_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      API_KEY: "{{ dify_docker_sandbox_api_key }}"
      GIN_MODE: "release"
      WORKER_TIMEOUT: "15"
      ENABLE_NETWORK: "true"
      HTTP_PROXY: "http://ssrf_proxy:{{ dify_docker_ssrf_proxy_port }}"
      HTTPS_PROXY: "http://ssrf_proxy:{{ dify_docker_ssrf_proxy_port }}"
      SANDBOX_PORT: "{{ dify_docker_sandbox_port }}"
    depends_on:
      - ssrf_proxy
    volumes:
      - {{ dify_docker_data_dir }}/sandbox/dependencies:/dependencies

  ssrf_proxy:
    image: {{ dify_docker_ssrf_proxy_image }}
    restart: {{ dify_docker_restart_policy }}
    volumes:
      - {{ dify_docker_data_dir }}/ssrf_proxy/squid.conf:/etc/squid/squid.conf:ro

  # Plugin runtime — serves model providers + the marketplace on 1.x. Uses its
  # own `dify_plugin` database. ponytail: kept on the flat compose network like
  # the sibling roles rather than replicating upstream's isolated
  # ssrf_proxy_network; the squid `deny to_private_networks` rule is the active
  # SSRF control. Add the network split if plugin code must be hard-isolated.
  plugin_daemon:
    image: {{ dify_docker_plugin_daemon_image }}
    restart: {{ dify_docker_restart_policy }}
    environment:
      DB_HOST: "db"
      DB_PORT: "{{ dify_docker_postgres_port }}"
      DB_USERNAME: "{{ dify_docker_db_user }}"
      DB_PASSWORD: "{{ dify_docker_db_password }}"
      DB_DATABASE: "{{ dify_docker_plugin_db_name }}"
      DB_SSL_MODE: "disable"
      REDIS_HOST: "redis"
      REDIS_PORT: "{{ dify_docker_redis_port }}"
      REDIS_PASSWORD: "{{ dify_docker_redis_password }}"
      SERVER_PORT: "{{ dify_docker_plugin_daemon_port }}"
      SERVER_KEY: "{{ dify_docker_plugin_daemon_key }}"
      DIFY_INNER_API_URL: "http://api:{{ dify_docker_api_port }}"
      DIFY_INNER_API_KEY: "{{ dify_docker_inner_api_key }}"
      MAX_PLUGIN_PACKAGE_SIZE: "52428800"
      PPROF_ENABLED: "false"
      FORCE_VERIFYING_SIGNATURE: "true"
      PLUGIN_REMOTE_INSTALLING_HOST: "0.0.0.0"
      PLUGIN_REMOTE_INSTALLING_PORT: "5003"
      PLUGIN_WORKING_PATH: "/app/storage/cwd"
      PYTHON_ENV_INIT_TIMEOUT: "120"
      PLUGIN_MAX_EXECUTION_TIMEOUT: "600"
      PLUGIN_STORAGE_TYPE: "local"
      PLUGIN_STORAGE_LOCAL_ROOT: "/app/storage"
    depends_on:
      - db
      - redis
    volumes:
      - {{ dify_docker_data_dir }}/plugin_daemon:/app/storage

  nginx:
    image: {{ dify_docker_nginx_image }}
    container_name: "{{ dify_docker_container_name }}"
    restart: {{ dify_docker_restart_policy }}
    depends_on:
      - api
      - web
      - plugin_daemon
    volumes:
      - {{ dify_docker_data_dir }}/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    ports:
      - "{{ dify_docker_web_port }}:80"
