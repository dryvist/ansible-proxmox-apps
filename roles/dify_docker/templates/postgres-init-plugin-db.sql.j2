-- Rendered by Ansible (dify_docker role). Mounted into the postgres
-- /docker-entrypoint-initdb.d and run ONCE on first init (empty PGDATA) to
-- create the separate database the plugin_daemon uses. Idempotent via \gexec so
-- a re-run against an already-initialized cluster is a no-op instead of an error.
SELECT 'CREATE DATABASE {{ dify_docker_plugin_db_name }}'
WHERE NOT EXISTS (
  SELECT FROM pg_database WHERE datname = '{{ dify_docker_plugin_db_name }}'
)\gexec
