---
services:
{% for repo_entry in _github_runner_repos %}
{% set repo_slug = repo_entry.repo.split('/')[1] | regex_replace('[^a-zA-Z0-9]', '_') %}
{% set replicas = repo_entry.replicas | default(github_runner_default_replicas) %}
{% set labels = repo_entry.labels | default(github_runner_default_labels) %}
{% set name_prefix = repo_entry.name_prefix | default(github_runner_default_name_prefix) %}
{% set cpu_limit = repo_entry.cpu_limit | default(github_runner_default_cpu_limit) %}
{% set memory_limit = repo_entry.memory_limit | default(github_runner_default_memory_limit) %}
  runner_{{ repo_slug }}:
    image: "{{ github_runner_image_name }}:{{ github_runner_image_tag }}"
    cpus: {{ cpu_limit }}
    mem_limit: "{{ memory_limit }}"
    environment:
      GITHUB_REPOSITORY: "{{ repo_entry.repo }}"
{% if github_runner_admin_token is defined %}
      GH_TOKEN: "{{ github_runner_admin_token }}"
{% elif github_runner_token is defined %}
      RUNNER_TOKEN: "{{ github_runner_token }}"
{% endif %}
{% if github_runner_sops_age_key is defined %}
      SOPS_AGE_KEY: "{{ github_runner_sops_age_key }}"
{% endif %}
      RUNNER_LABELS: "{{ labels }}"
      RUNNER_NAME_PREFIX: "{{ name_prefix }}-{{ repo_slug }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    # The runner user must be able to write the bind-mounted host socket; the
    # host's docker group GID is looked up at converge time (never hardcoded —
    # runner 2.336.0's image dropped the incidental in-image GID match that
    # made this work before).
    group_add:
      - "{{ github_runner_docker_gid }}"
    restart: unless-stopped
    networks:
      - ci_runners
    deploy:
      replicas: {{ replicas }}

{% endfor %}
networks:
  ci_runners:
    name: ci_runners
    driver: bridge
    driver_opts:
      com.docker.network.bridge.enable_ip_masquerade: "true"
