---
# Cribl Edge inputs configuration
# Generated by Ansible - do not edit manually

inputs:
{% for name, port in cribl_edge_syslog_port_mappings.items() %}
  in_syslog_{{ port }}:
    id: in_syslog_{{ port }}
    type: syslog
    disabled: false
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: syslog
    host: "0.0.0.0"
    tcpPort: {{ port }}
    udpPort: {{ port }}
    pqEnabled: true
    fields:
      - name: type
        value: "'syslog'"

{% endfor %}
  # Splunk-HEC source for the per-WAN netmon probers (roles/netmon Telegraf
  # outputs.http). Routed to the netmon pipeline -> Splunk netmon index.
  in_netmon_hec:
    id: in_netmon_hec
    type: splunk_hec
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_edge_hec_input_port }}
    splunkHecAPI: /services/collector
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: netmon
    pqEnabled: true
    tls:
      disabled: true
{% if cribl_edge_hec_input_token | length > 0 %}
    authTokens:
      - token: "{{ cribl_edge_hec_input_token }}"
        enabled: true
{% else %}
    authTokens: []
{% endif %}
    fields:
      - name: type
        value: "'netmon'"
