---
# Cribl Edge inputs configuration
# Generated by Ansible - do not edit manually

inputs:
{% for name, port in cribl_edge_syslog_port_mappings.items() %}
  in_syslog_{{ port }}:
    id: in_syslog_{{ port }}
    type: syslog
    disabled: false
    sendToRoutes: false
    connections:
{% if (cribl_edge_hec_namespace | default('')) | length > 0 %}
      # One index per HEC: this syslog family maps to a single Splunk index, so
      # send directly to that index's dedicated HEC output (no router needed).
      - output: splunk_hec_{{ cribl_edge_syslog_routing[name].index }}
        pipeline: syslog
{% else %}
      - output: splunk_hec
        pipeline: syslog
{% endif %}
    host: "0.0.0.0"
    tcpPort: {{ port }}
    udpPort: {{ port }}
    pqEnabled: true
    fields:
      - name: type
        value: "'syslog'"

{% endfor %}
  # Splunk-HEC source for the per-WAN netmon probers (roles/netmon Telegraf
  # outputs.http). Routed to the netmon pipeline -> Splunk netmon index.
  in_netmon_hec:
    id: in_netmon_hec
    type: splunk_hec
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_edge_hec_input_port }}
    splunkHecAPI: /services/collector
    sendToRoutes: false
    connections:
{% if (cribl_edge_hec_namespace | default('')) | length > 0 %}
      # Per-index HEC: this input currently carries ONLY unifi_metrics (the
      # netmon per-WAN probers are not deployed), so it pins directly to the
      # dedicated unifi_metrics HEC output. The netmon pipeline still stamps the
      # index. NOTE: if/when the netmon probers are deployed, they push to this
      # same HEC port — split them off via the 4.12 routes table (routes.yml
      # already fans the otel input out this way) or a dedicated HEC input.
      - output: splunk_hec_unifi_metrics
        pipeline: netmon
{% else %}
      - output: splunk_hec
        pipeline: netmon
{% endif %}
    pqEnabled: true
    tls:
      disabled: true
{% if cribl_edge_hec_input_token | length > 0 %}
    authTokens:
      - token: "{{ cribl_edge_hec_input_token }}"
        enabled: true
{% else %}
    authTokens: []
{% endif %}
    fields:
      - name: type
        value: "'netmon'"
{% if cribl_edge_langfuse_public_key | length > 0 %}

  # OTLP/HTTP source for the LLM fabric (routers, dify/langflow/agent-exec).
  # Fanned out via the routes table (routes.yml, 4.12+): otel_langfuse
  # (non-final, trace-only -> Langfuse) then otel_splunk (final, stamps
  # index=otel -> Splunk HEC). sendToRoutes replaces the old single pinned
  # connection — routes CAN split one input across outputs since 4.12.
  in_otel:
    id: in_otel
    type: open_telemetry
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_edge_otel_port }}
    protocol: http
    # Must match the destination's OTLP version: the input's default (0.10.0)
    # decodes into instrumentation_library_* field names that a 1.3.1
    # destination cannot re-serialize ("Event had no scope_spans"), silently
    # dropping every span.
    otlpVersion: "1.3.1"
    # Spans must be extracted into first-class span events: with extraction off
    # the OTel destination cannot re-serialize the wrapped payload and drops
    # every event ("Event had no scope_metrics or __criblMetrics").
    extractSpans: true
    extractMetrics: false
    # Routes-table fan-out (4.12+): otel_langfuse applies the otel_traces
    # trace-only filter pipeline before the Langfuse destination; otel_splunk
    # stamps index=otel for the Splunk leg. See routes.yml.j2.
    sendToRoutes: true
    pqEnabled: true
    fields:
      - name: type
        value: "'otel'"
{% endif %}
