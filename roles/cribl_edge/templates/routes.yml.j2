---
# Cribl Edge routes table (4.12+)
# Generated by Ansible - do not edit manually
#
# Only the otel input sends to routes (every other input pins a direct
# input->pipeline->output connection with sendToRoutes: false, so events from
# those inputs never reach this table). Since 4.12 routes CAN split one input
# across outputs: a NON-final otel_langfuse route clones the stream into
# Langfuse (traces only, via the otel_traces filter pipeline), then the FINAL
# otel_splunk route stamps index=otel and ships the same events to Splunk.
id: default
routes:
{% if cribl_edge_langfuse_public_key | length > 0 %}
  - id: otel_langfuse
    name: otel_langfuse
    final: false
    disabled: false
    filter: "__inputId.includes('in_otel')"
    pipeline: otel_traces
    output: langfuse_otlp
    description: LLM fabric traces -> Langfuse (non-final; clones the stream)
{% endif %}
  - id: otel_splunk
    name: otel_splunk
    final: true
    disabled: false
    filter: "__inputId.includes('in_otel')"
    pipeline: otel_splunk
{% if (cribl_edge_hec_namespace | default('')) | length > 0 %}
    output: splunk_hec_otel
{% else %}
    output: splunk_hec
{% endif %}
    description: LLM fabric OTel -> Splunk (final; index=otel)
  # Defensive catch-all: nothing should reach here (all non-otel inputs pin
  # direct connections), but a final route keeps any stray event from
  # dead-ending with a routing error. main/devnull come from Cribl defaults.
  - id: default
    name: default
    final: true
    disabled: false
    filter: "true"
    pipeline: main
    output: devnull
