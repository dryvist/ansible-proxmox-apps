---
# Syslog processing pipeline
# Generated by Ansible - do not edit manually

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        # index/sourcetype conditionals are generated from the tofu
        # syslog_port_map (cribl_edge_syslog_routing) — routing truth lives
        # in terraform-proxmox constants, not here. The unifi family gets a
        # firewall/IPS split first: raw lines matching
        # cribl_edge_unifi_fw_match re-route to index=firewall
        # sourcetype=ubiquiti:firewall before the plain unifi branch.
        - name: index
          value: >-
{% for family, entry in cribl_edge_syslog_routing | dictsort %}
{% if family == 'unifi' %}
            __inputId.includes('{{ entry.high }}') && /{{ cribl_edge_unifi_fw_match }}/.test(_raw) ? 'firewall' :
{% endif %}
            __inputId.includes('{{ entry.high }}') ? '{{ entry.index }}' :
{% endfor %}
            'main'
        - name: sourcetype
          value: >-
{% for family, entry in cribl_edge_syslog_routing | dictsort %}
{% if family == 'unifi' %}
            __inputId.includes('{{ entry.high }}') && /{{ cribl_edge_unifi_fw_match }}/.test(_raw) ? 'ubiquiti:firewall' :
{% endif %}
            __inputId.includes('{{ entry.high }}') ? '{{ entry.sourcetype }}' :
{% endfor %}
            'syslog'
        - name: source
          value: "'syslog:' + ((__inputId.match(/\\d{4}/) || ['0000'])[0])"

  # Hardware reclassify: host OS-syslog lines matching disk/SMART/ZFS failure
  # signatures (cribl_edge_hardware_match) move index=os -> index=hardware. The
  # splunk_hec_os_router (outputs.yml.j2) reads this stamped index and ships the
  # matches to the dedicated hardware HEC output instead of the os catch-all —
  # so the signature list lives ONLY here, never duplicated in a route filter.
  # Scoped to index=='os' (just stamped above), so only the linux/windows OS
  # families are reclassified, never the app/network syslog families.
  - id: eval
    # Folded block scalar (not a double-quoted string) so the regex backslashes
    # (\b, \/) stay literal for Cribl — YAML would reject/rewrite them in a
    # quoted scalar. Same convention as the unifi index eval's value block.
    filter: >-
      index == 'os' && /{{ cribl_edge_hardware_match }}/i.test(_raw)
    disabled: false
    conf:
      add:
        - name: index
          value: "'hardware'"

  - id: regex_extract
    filter: "!__inputId.includes('ipfix')"
    disabled: false
    conf:
      source: _raw
      iterations: 100
      overwrite: false
      regex: /^<\d+>(?:\d+ )?(?:(?<timestamp>\w{3}\s+\d+\s+[\d:]+)|(?<timestamp_iso>\d{4}-\d{2}-\d{2}T[\d:.Z+-]+))\s+(?<log_host>\S+)\s+(?<process>[^\[:\s]+)(?:\[(?<pid>\d+)\])?[:\s]+(?<message>.*)/

{% if 'proxy' in cribl_edge_syslog_routing %}
  # The proxy family carries BOTH traefik and haproxy program routes on one
  # port ({{ cribl_edge_syslog_routing.proxy.high }}); refine the sourcetype
  # from the syslog-header program name (`process`, extracted above) AFTER
  # regex_extract has run. Unknown programs keep the family sourcetype.
  - id: eval
    filter: "__inputId.includes('{{ cribl_edge_syslog_routing.proxy.high }}') && process != null"
    disabled: false
    conf:
      add:
        - name: sourcetype
          value: >-
            process === 'traefik' ? 'traefik:syslog'
            : process === 'haproxy' ? 'haproxy:syslog'
            : sourcetype

{% endif %}
  - id: eval
    filter: log_host != null
    disabled: false
    conf:
      add:
        - name: host
          value: log_host

  - id: eval
    filter: "true"
    disabled: false
    conf:
      remove:
        - log_host
        - timestamp_iso
