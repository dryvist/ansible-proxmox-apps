---
# Syslog processing pipeline
# Generated by Ansible - do not edit manually

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        # index/sourcetype conditionals are generated from the tofu
        # syslog_port_map (cribl_edge_syslog_routing) — routing truth lives
        # in terraform-proxmox constants, not here.
        - name: index
          value: >-
{% for family, entry in cribl_edge_syslog_routing | dictsort %}
            __inputId.includes('{{ entry.high }}') ? '{{ entry.index }}' :
{% endfor %}
            'main'
        - name: sourcetype
          value: >-
{% for family, entry in cribl_edge_syslog_routing | dictsort %}
            __inputId.includes('{{ entry.high }}') ? '{{ entry.sourcetype }}' :
{% endfor %}
            'syslog'
        - name: source
          value: "'syslog:' + ((__inputId.match(/\\d{4}/) || ['0000'])[0])"

  - id: regex_extract
    filter: "!__inputId.includes('ipfix')"
    disabled: false
    conf:
      source: _raw
      iterations: 100
      overwrite: false
      regex: /^<\d+>(?:\d+ )?(?:(?<timestamp>\w{3}\s+\d+\s+[\d:]+)|(?<timestamp_iso>\d{4}-\d{2}-\d{2}T[\d:.Z+-]+))\s+(?<log_host>\S+)\s+(?<process>[^\[:\s]+)(?:\[(?<pid>\d+)\])?[:\s]+(?<message>.*)/

  - id: eval
    filter: log_host != null
    disabled: false
    conf:
      add:
        - name: host
          value: log_host

  - id: eval
    filter: "true"
    disabled: false
    conf:
      remove:
        - log_host
        - timestamp_iso
