---
# OTLP trace filter for the in_otel source (pre-processing pipeline)
# Generated by Ansible - do not edit manually
#
# The fabric's OTLP producers (dify's auto-instrumentation in particular) send
# metrics and logs alongside traces on the same endpoint. The Langfuse OTLP
# destination ingests TRACES ONLY — anything else errors, retries, and backs
# the persistent queue up until real spans stop flowing. Drop non-trace
# signals at the input instead.

output: langfuse_otlp
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: drop
    filter: "!__otlp || __otlp.type !== 'traces'"
    disabled: false
    conf: {}
