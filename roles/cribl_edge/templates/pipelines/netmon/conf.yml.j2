---
# Netmon (per-WAN prober) processing pipeline
# Generated by Ansible - do not edit manually
#
# Telegraf on the netmon probers pushes Splunk-HEC to the in_netmon_hec source;
# this pipeline stamps the Splunk index/sourcetype and reuses the shared
# splunk_hec output. Per-WAN tags (prober, uplink) ride along on the events.

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        - name: index
          value: "'netmon'"
        - name: sourcetype
          value: "'telegraf:netmon'"
        - name: source
          value: "'telegraf:hec'"
