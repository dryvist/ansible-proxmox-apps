---
# PVE host-metrics stamping pipeline (in_prometheus_pve source)
# Generated by Ansible - do not edit manually
#
# The prometheus input scrapes each commissioned node's node_exporter; this
# pipeline stamps the Splunk metric index/sourcetype before the per-index HEC
# output. Conditional evals (`index || ...`) so a pre-stamped event passes
# untouched, matching the ai_stamp convention on Stream.

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        - name: index
          value: "index || 'host_metrics'"
        - name: sourcetype
          value: "sourcetype || 'node_exporter'"
        - name: source
          value: "source || 'prometheus:pve'"
