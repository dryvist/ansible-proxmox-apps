---
# Splunk leg of the OTel routes fan-out (4.12+)
# Generated by Ansible - do not edit manually
#
# The otel_splunk route sends the FULL otel stream here (spans extracted by
# the input); stamp Splunk metadata conditionally (`index || ...`) so any
# producer that already set them passes through untouched.

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        - name: index
          value: "index || 'otel'"
        - name: sourcetype
          value: "sourcetype || 'otel:span'"
        - name: source
          value: "source || 'cribl-edge-otel'"
