---
# Cribl Edge instance settings
# Generated by Ansible - do not edit manually
#
# default/edge/cribl.yml binds the API to 127.0.0.1:9420, which makes the
# health endpoint unreachable from the network. Bind 0.0.0.0 so playbook
# validation and E2E tests can reach the API; the Proxmox firewall already
# restricts this port to internal sources.
api:
  host: "0.0.0.0"
  port: {{ cribl_edge_api_port }}
