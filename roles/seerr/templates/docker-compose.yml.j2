---
# Generated by Ansible (seerr role). Do not edit manually.
# Config (settings.json, db) persists to the bind-mounted host dir.
services:
  seerr:
    container_name: {{ seerr_container_name }}
    image: {{ seerr_image }}
    # Seerr's image ships no init process; init: true reaps zombies (PID 1).
    init: true
    restart: unless-stopped
    ports:
      - "{{ seerr_bind_address }}:{{ seerr_web_port }}:5055"
    environment:
      TZ: "{{ seerr_tz }}"
      LOG_LEVEL: "{{ seerr_log_level }}"
      PORT: "5055"
    volumes:
      - {{ seerr_config_dir }}:/app/config
