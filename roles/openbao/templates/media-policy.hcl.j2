{{ ansible_managed | comment }}
# OpenBao policy for the media AppRole — the *arr/qBittorrent/Plex stack.
# Read-only, no access to the infra kernel or other app/platform services.

path "{{ openbao_kv_mount }}/data/apps/media/*" {
  capabilities = ["read"]
}

path "{{ openbao_kv_mount }}/metadata/apps/media/*" {
  capabilities = ["read", "list"]
}
