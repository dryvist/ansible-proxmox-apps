{{ ansible_managed | comment }}
# OpenBao policy for the terraform-apply AppRole — human-triggered IaC apply.
# Read/write on the infra kernel (it provisions those secrets) plus the
# dns/traefik platform subtrees, plus the legacy homelab demo subtree the
# vault-secrets read/write proof uses. Deliberately NOT the rest of
# secret/platform/* (e.g. terrakube) — that's the terrakube-plan identity,
# kept separate because Terrakube executes untrusted VCS-driven plans and
# must never be able to read or rewrite the infra kernel. KV v2 splits data
# and metadata paths, so both are listed explicitly.

{% for sub in ['infra', openbao_homelab_path] %}
path "{{ openbao_kv_mount }}/data/{{ sub }}/*" {
  capabilities = ["create", "read", "update", "delete"]
}

path "{{ openbao_kv_mount }}/metadata/{{ sub }}/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

{% endfor %}
{% for sub in ['dns', 'traefik'] %}
path "{{ openbao_kv_mount }}/data/platform/{{ sub }}/*" {
  capabilities = ["create", "read", "update", "delete"]
}

path "{{ openbao_kv_mount }}/metadata/platform/{{ sub }}/*" {
  capabilities = ["create", "read", "update", "delete", "list"]
}

{% endfor %}
