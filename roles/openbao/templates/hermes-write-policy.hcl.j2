{{ ansible_managed | comment }}
# OpenBao policy for the hermes-write AppRole — a single-purpose writer scoped
# to the exact Hermes credential secret and nothing else:
# the one-time Hermes credential seed writes ai/hermes, while ansible-converge
# owns publication to the separate shared MCP secrets. Deliberately NO
# wildcard, NO other ai/* paths, and NO infra/platform/apps. Update-in-place is
# a read-modify-write on a known path, so `read` on the exact secret is enough —
# no `list`.
# See terraform-proxmox docs/SECRETS_HIERARCHY.md.

path "{{ openbao_kv_mount }}/data/ai/hermes" {
  capabilities = ["create", "update", "read"]
}

path "{{ openbao_kv_mount }}/metadata/ai/hermes" {
  capabilities = ["read"]
}
