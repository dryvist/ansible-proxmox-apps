{{ ansible_managed | comment }}
# BASE CAPABILITY policy `github-mint` — actor-agnostic, mint-only. Grants ONLY
# the READ-tier GitHub App permission sets (ephemeral installation tokens) so a
# run's API reads are attributed to a per-run token, not a standing PAT. The
# admin-tier *-full-automation sets (installation-wide, full App ceiling), the
# raw {{ openbao_github_mount }}/token endpoint, and the engine's config/* +
# permissionset/* administration paths are ABSENT, so an actor holding this
# capability can only mint the read sets — it cannot widen the token's scope.
# Per-repo WRITE minting is the github-write identity's policy alone; an estate
# identity that needs repo write gets its own parameter-pinned grant, never
# this leaf widened. Attached (via token_policies) to the apply-tier actor
# roles; carries no self-escalation path, so composing it with KV leaves is safe.
{% for permission_set in openbao_github_permission_sets | rejectattr('tier', 'equalto', 'admin') %}
path "{{ openbao_github_mount }}/token/{{ permission_set.name }}" {
  capabilities = ["create", "update"]
}

{% endfor %}
