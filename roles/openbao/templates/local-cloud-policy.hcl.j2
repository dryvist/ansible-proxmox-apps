{{ ansible_managed | comment }}
# OpenBao policy for the local-cloud AppRole — object storage (RustFS) and
# compute credentials. Read-only, no access to the infra kernel or other
# platform services.

{% for sub in ['object-storage', 'compute'] %}
path "{{ openbao_kv_mount }}/data/platform/{{ sub }}/*" {
  capabilities = ["read"]
}

path "{{ openbao_kv_mount }}/metadata/platform/{{ sub }}/*" {
  capabilities = ["read", "list"]
}

{% endfor %}
