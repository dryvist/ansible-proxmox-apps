---
# Generated by Ansible (immich role). Do not edit manually.
# Mirrors Immich's upstream compose; values come from the sibling .env file.
services:
  immich-server:
    container_name: {{ immich_container_name }}
    image: ghcr.io/immich-app/immich-server:${IMMICH_VERSION:-release}
    volumes:
      - ${UPLOAD_LOCATION}:/data
    env_file:
      - .env
    ports:
      - "{{ immich_bind_address }}:{{ immich_web_port }}:2283"
    depends_on:
      - redis
      - database
    restart: always
    healthcheck:
      disable: false

  immich-machine-learning:
    container_name: {{ immich_ml_container_name }}
    image: ghcr.io/immich-app/immich-machine-learning:${IMMICH_VERSION:-release}
    volumes:
      - model-cache:/cache
    env_file:
      - .env
    restart: always
    healthcheck:
      disable: false

  redis:
    container_name: {{ immich_redis_container_name }}
    image: {{ immich_redis_image }}
    healthcheck:
      test: redis-cli ping || exit 1
    restart: always

  database:
    container_name: {{ immich_postgres_container_name }}
    image: {{ immich_postgres_image }}
    environment:
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_USER: ${DB_USERNAME}
      POSTGRES_DB: ${DB_DATABASE_NAME}
      POSTGRES_INITDB_ARGS: '--data-checksums'
    shm_size: 128mb
    volumes:
      - ${DB_DATA_LOCATION}:/var/lib/postgresql/data
    restart: always
    healthcheck:
      test: pg_isready --dbname="${DB_DATABASE_NAME}" --username="${DB_USERNAME}" || exit 1
      interval: 30s
      timeout: 5s
      retries: 5

volumes:
  model-cache:
