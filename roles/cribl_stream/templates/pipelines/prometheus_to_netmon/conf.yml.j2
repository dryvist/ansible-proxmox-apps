---
# Prometheus remote_write → Splunk netmon pipeline
# Generated by Ansible.
#
# The prometheus_rw source emits one event per sample with fields:
#   metric_name, value, _time, and one field per label (job, instance, etc.)
# We stamp index/sourcetype and derive host from the job label so SPL
# queries read: index=netmon_metrics sourcetype="prometheus:metrics" metric_name=probe_success
output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        # ponytail: coerce null/NaN/string metric values to -1 so the Splunk
        # metric index never rejects them (blackbox emits NaN series, e.g.
        # probe_ssl_earliest_cert_expiry on a failed/non-TLS probe, which arrive
        # as null). -1 = "no valid measurement". Also upgrades numeric strings.
        - name: value
          value: "Number.isFinite(Number(value)) ? Number(value) : -1"
        # Job-keyed index split: the pve_node_exporter job (PVE host metrics —
        # scraped by the prometheus LXC because the Cribl prometheus scraper
        # source is not allowed on standalone deployments) lands in the
        # host_metrics metric index; every other job keeps netmon_metrics.
        - name: index
          value: "job === 'pve_node_exporter' ? 'host_metrics' : 'netmon_metrics'"
        - name: sourcetype
          value: "job === 'pve_node_exporter' ? 'node_exporter' : 'prometheus:metrics'"
        # node_exporter identity is its instance (fqdn:port) — strip the port
        # and domain so host matches the syslog family's plain node hostname.
        - name: host
          value: "job === 'pve_node_exporter' ? (instance || '').replace(/:\\d+$/, '').replace(/\\..*$/, '') : (target || instance || job || 'prometheus')"
