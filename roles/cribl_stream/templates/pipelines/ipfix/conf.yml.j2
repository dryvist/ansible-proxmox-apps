---
# IPFIX/NetFlow processing pipeline
# Generated by Ansible

output: splunk_hec
streamtags: []
groups: {}
asyncFuncTimeout: 1000
functions:
  - id: eval
    filter: "true"
    disabled: false
    conf:
      add:
        - name: index
          value: "'netflow'"
        - name: sourcetype
          value: "'ipfix'"
        - name: source
          value: "'ipfix:' + String(__e['ipfix.port'] || {{ cribl_stream_netflow_port }})"
