---
# Cribl Stream inputs configuration
# Generated by Ansible

inputs:
  netflow:in_ipfix:
    id: in_ipfix
    type: netflow
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_stream_netflow_port }}
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: ipfix
    pqEnabled: {{ cribl_stream_pq_enabled | lower }}
  cribl_tcp:in_cribl_s2s:
    id: in_cribl_s2s
    type: cribl_tcp
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_stream_s2s_port }}
    # Remote Edge nodes stamp index/sourcetype at the source; pass events
    # straight to the Splunk HEC output (no pipeline = passthrough).
    sendToRoutes: false
    connections:
      - output: splunk_hec
    pqEnabled: {{ cribl_stream_pq_enabled | lower }}
