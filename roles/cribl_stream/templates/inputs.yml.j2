---
# Cribl Stream inputs configuration
# Generated by Ansible

inputs:
  netflow:in_ipfix:
    id: in_ipfix
    type: netflow
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_stream_netflow_port }}
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: ipfix
    pqEnabled: {{ cribl_stream_pq_enabled | lower }}
  tcpjson:in_cribl_s2s:
    id: in_cribl_s2s
    # TCP JSON, not cribl_tcp: the Cribl TCP source is only available in
    # DISTRIBUTED Stream deployments and fails on this single-instance Stream
    # with "Source is not allowed in this deployment". TCP JSON is Cribl's
    # documented single-instance equivalent; the remote Edge ships with the
    # matching tcpjson destination on the same port.
    type: tcpjson
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_stream_s2s_port }}
    # Remote Edge nodes stamp index/sourcetype where they can, but Cribl
    # Edge provably skips its destination post-processing pipeline for
    # pack-routed events (claude/gemini transcripts arrived with datatype
    # but no index/sourcetype and fell into Splunk's token defaults:
    # index=main, sourcetype=httpevent). The force_splunk_meta connection
    # pipeline is a conditional safety net: every eval is `index || ...`,
    # so events the Edge DID stamp pass through untouched.
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: force_splunk_meta
    pqEnabled: {{ cribl_stream_pq_enabled | lower }}
  prometheus_rw:in_prometheus_rw:
    id: in_prometheus_rw
    type: prometheus_rw
    disabled: false
    host: "0.0.0.0"
    port: {{ cribl_stream_prometheus_rw_port }}
    sendToRoutes: false
    connections:
      - output: splunk_hec
        pipeline: prometheus_to_netmon
    pqEnabled: {{ cribl_stream_pq_enabled | lower }}
