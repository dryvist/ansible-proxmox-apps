---
# yamllint configuration compatible with ansible-lint
# See: https://ansible.readthedocs.io/projects/lint/rules/yaml/

extends: default

ignore: |
  .github/aw/
  .github/workflows/*.lock.yml
  .github/workflows/agentics-maintenance.yml
  # SOPS-encrypted files have long base64 lines and non-standard
  # indentation that linting cannot meaningfully evaluate. Recursive
  # glob matches the `.sops.yaml` rule (`\.enc\.ya?ml$`) and catches
  # any future encrypted files in subdirectories.
  **/*.enc.yaml
  **/*.enc.yml

rules:
  line-length:
    max: 120
    level: warning
  indentation:
    spaces: 2
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on']
  # Required by ansible-lint
  comments-indentation: false
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
